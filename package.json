    "hono": "^4.12.9",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  }
